<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4A4ECF">

    <!-- Logo App -->
    <ImageView
        android:id="@+id/logo_center"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/logobmii"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Judul -->
    <TextView
        android:id="@+id/tv_judul_tips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TIPS BADAN IDEAL"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/logo_center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- VIEW PAGER 2 (Sudah diperbaiki atribut bottom-nya maseh) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerTips"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_marginTop="20dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintTop_toBottomOf="@id/tv_judul_tips"
        app:layout_constraintBottom_toTopOf="@+id/btn_kembali_tips" />

    <!-- Tombol Kembali -->
    <Button
        android:id="@+id/btn_kembali_tips"
        android:layout_width="200dp"
        android:layout_height="55dp"
        android:layout_marginBottom="40dp"
        android:backgroundTint="@android:color/white"
        android:text="KEMBALI"
        android:textColor="#4A4ECF"
        android:textStyle="bold"
        app:cornerRadius="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>